{
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov"
  ],
  "report-dir": "coverage",
  "temp-dir": ".nyc_output",
  "all": true,
  "include": [
    "lib/**/*.js"
  ],
  "exclude": [
    "test/**",
    "load/**",
    "coverage/**",
    ".nyc_output/**",
    "node_modules/**"
  ],
  "check-coverage": true,
  "lines": 80,
  "statements": 80,
  "functions": 85,
  "branches": 55
}
